{
  "tool": "moji",
  "module": "calc.js",
  "global": "MojiCalc",
  "cases": [
    {
      "name": "「あいう えお」+改行+「かき」: 8文字(スペース込み)・7文字(除く)・2行",
      "func": "count",
      "args": [
        "あいう えお\nかき"
      ],
      "expect": {
        "ok": true,
        "chars": 8,
        "charsNoSpace": 7,
        "lines": 2,
        "genkoyoshi": 1
      }
    },
    {
      "name": "空文字は0文字・0行",
      "func": "count",
      "args": [
        ""
      ],
      "expect": {
        "ok": true,
        "chars": 0,
        "charsNoSpace": 0,
        "lines": 0,
        "genkoyoshi": 0
      }
    },
    {
      "name": "絵文字はサロゲートペアでも1文字と数える",
      "func": "count",
      "args": [
        "🍣🍺"
      ],
      "expect": {
        "ok": true,
        "chars": 2,
        "charsNoSpace": 2
      }
    },
    {
      "name": "全角スペースも「スペース除く」で除外",
      "func": "count",
      "args": [
        "あ　い"
      ],
      "expect": {
        "ok": true,
        "chars": 3,
        "charsNoSpace": 2
      }
    },
    {
      "name": "英数字混在",
      "func": "count",
      "args": [
        "Hello 世界!"
      ],
      "expect": {
        "ok": true,
        "chars": 9,
        "charsNoSpace": 8,
        "lines": 1
      }
    },
    {
      "name": "改行のみは文字数0・2行",
      "func": "count",
      "args": [
        "\n"
      ],
      "expect": {
        "ok": true,
        "chars": 0,
        "lines": 2
      }
    },
    {
      "name": "401文字は原稿用紙2枚",
      "func": "count",
      "args": [
        "あああああああああああああああああああああああああああああああああああああああああああああああああああああああああああああああああああああああああああああああああああああああああああああああああああああああああああああああああああああああああああああああああああああああああああああああああああああああああああああああああああああああああああああああああああああああああああああああああああああああああああああああああああああああああああああああああああああああああああああああああああああああああああああああああああああああああああああああああああああああああああああああああああああああああああああああああああああああああああああああああああああああああああああああああああああああああああああああああああああああああああああああああああああああああああああああああああああああああああああああああ"
      ],
      "expect": {
        "ok": true,
        "chars": 401,
        "genkoyoshi": 2
      }
    },
    {
      "name": "異常入力: 文字列以外はエラー",
      "func": "count",
      "args": [
        123
      ],
      "expect": {
        "ok": false,
        "code": "invalid_text"
      }
    }
  ]
}
