{
  "tool": "bmi",
  "module": "calc.js",
  "global": "BmiCalc",
  "cases": [
    {
      "name": "標準的な入力(170cm/60kg)",
      "func": "calculate",
      "args": [170, 60],
      "expect": { "ok": true, "bmi": 20.8, "category": "普通体重", "idealWeightKg": 63.6 }
    },
    {
      "name": "境界値: BMIちょうど18.5は普通体重(160cm/47.36kg)",
      "func": "calculate",
      "args": [160, 47.36],
      "expect": { "ok": true, "bmi": 18.5, "category": "普通体重", "idealWeightKg": 56.3 }
    },
    {
      "name": "境界値未満: BMI18.4は低体重(160cm/47.0kg)",
      "func": "calculate",
      "args": [160, 47.0],
      "expect": { "ok": true, "bmi": 18.4, "category": "低体重" }
    },
    {
      "name": "境界値: BMIちょうど25.0は肥満(1度)(160cm/64kg)",
      "func": "calculate",
      "args": [160, 64],
      "expect": { "ok": true, "bmi": 25.0, "category": "肥満(1度)" }
    },
    {
      "name": "境界値直下: BMI24.6は普通体重(160cm/63kg)",
      "func": "calculate",
      "args": [160, 63],
      "expect": { "ok": true, "bmi": 24.6, "category": "普通体重" }
    },
    {
      "name": "境界値: BMI30台は肥満(2度)(160cm/78kg)",
      "func": "calculate",
      "args": [160, 78],
      "expect": { "ok": true, "bmi": 30.5, "category": "肥満(2度)" }
    },
    {
      "name": "肥満(3度)の判定(160cm/90kg)",
      "func": "calculate",
      "args": [160, 90],
      "expect": { "ok": true, "bmi": 35.2, "category": "肥満(3度)" }
    },
    {
      "name": "肥満(4度)の判定(160cm/110kg)",
      "func": "calculate",
      "args": [160, 110],
      "expect": { "ok": true, "bmi": 43.0, "category": "肥満(4度)" }
    },
    {
      "name": "低体重の判定(150cm/30kg)",
      "func": "calculate",
      "args": [150, 30],
      "expect": { "ok": true, "bmi": 13.3, "category": "低体重", "idealWeightKg": 49.5 }
    },
    {
      "name": "異常入力: 身長0はエラー",
      "func": "calculate",
      "args": [0, 60],
      "expect": { "ok": false, "code": "invalid_height" }
    },
    {
      "name": "異常入力: 身長が範囲超過(300cm)はエラー",
      "func": "calculate",
      "args": [300, 60],
      "expect": { "ok": false, "code": "invalid_height" }
    },
    {
      "name": "異常入力: 体重0はエラー",
      "func": "calculate",
      "args": [170, 0],
      "expect": { "ok": false, "code": "invalid_weight" }
    },
    {
      "name": "異常入力: 体重が負の値はエラー",
      "func": "calculate",
      "args": [170, -5],
      "expect": { "ok": false, "code": "invalid_weight" }
    },
    {
      "name": "異常入力: 体重が範囲超過(500kg)はエラー",
      "func": "calculate",
      "args": [170, 500],
      "expect": { "ok": false, "code": "invalid_weight" }
    },
    {
      "name": "異常入力: 数値でない身長はエラー",
      "func": "calculate",
      "args": ["abc", 60],
      "expect": { "ok": false, "code": "invalid_height" }
    },
    {
      "name": "異常入力: 引数なしはエラー",
      "func": "calculate",
      "args": [],
      "expect": { "ok": false, "code": "invalid_height" }
    }
  ]
}
